# ============================================================================
# MinerU VLM server — Dataset Smelter (SmelterEI)
# Copy to .env and tweak. `docker compose up -d` reads these automatically.
# ============================================================================

# ---- VLM server port --------------------------------------------------------
# Host port the OpenAI-compatible VLM server is published on (container: 30000).
MINERU_VLM_PORT=30000

# ---- Models -----------------------------------------------------------------
# Where MinerU pulls/loads models from: huggingface | modelscope | local
# (modelscope is faster from mainland China.)
MINERU_MODEL_SOURCE=huggingface

# Host dir for the model cache — first run downloads weights here and reuses them.
MINERU_MODELS_DIR=./models
