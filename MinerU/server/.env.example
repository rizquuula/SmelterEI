# ============================================================================
# MinerU VLM server — Dataset Smelter (SmelterEI)
# Copy to .env and tweak. `docker compose up -d` reads these automatically.
# ============================================================================

# ---- VLM server port --------------------------------------------------------
# Host port the OpenAI-compatible VLM server is published on (container: 30000).
MINERU_VLM_PORT=30000

# ---- Models -----------------------------------------------------------------
# Pinned VLM. The server loads exactly this model (passed to `vllm serve`) instead
# of riding MinerU's built-in default. Default = MinerU2.5-Pro-2605 (1.2B).
#   - local weights: point this at a path under the mounted cache (see below).
MINERU_VLM_MODEL=opendatalab/MinerU2.5-Pro-2605-1.2B

# Download backend for MINERU_VLM_MODEL:
#   false (default) — vLLM fetches it from Hugging Face.
#   true            — vLLM fetches from ModelScope (faster in mainland China);
#                     set MINERU_VLM_MODEL to the matching OpenDataLab/... id.
VLLM_USE_MODELSCOPE=false

# Host dir for the model cache — first run downloads weights here and reuses them.
MINERU_MODELS_DIR=./models
