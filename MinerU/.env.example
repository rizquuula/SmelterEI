# ============================================================================
# MinerU — Dataset Smelter (SmelterEI)
# Copy to .env and tweak. `docker compose up -d` reads these automatically.
# ============================================================================

# ---- HTTP API ---------------------------------------------------------------
# Host port the MinerU FastAPI service is published on (container is always 8000).
MINERU_API_PORT=8000

# Max concurrent parse requests the API will handle (raise on bigger machines).
MINERU_API_MAX_CONCURRENT_REQUESTS=3

# ---- Compute ----------------------------------------------------------------
# cpu  -> this machine (default)
# cuda -> GPU host (also apply docker-compose.gpu.yaml)
MINERU_DEVICE_MODE=cpu

# ---- Models -----------------------------------------------------------------
# Where MinerU pulls/loads models from: huggingface | modelscope | local
# (modelscope is faster from mainland China.)
MINERU_MODEL_SOURCE=huggingface

# Host dir for the model cache — first run downloads a few GB here and reuses it.
MINERU_MODELS_DIR=./models

# ---- Output -----------------------------------------------------------------
# Host dir for parsed output (used when running the mineru CLI inside the container).
MINERU_OUTPUT_DIR=./output

# ---- Extraction features ----------------------------------------------------
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true

# ---- Backend / Remote model -------------------------------------------------
# Which backend the dataset generator should request when calling /file_parse:
#   pipeline         -> classic models, runs locally on CPU/GPU (default, no GPU needed)
#   vlm-http-client  -> offload VLM inference to a REMOTE server (no local GPU)
MINERU_BACKEND=pipeline
#
# When MINERU_BACKEND=vlm-http-client, point at the remote OpenAI-compatible
# vLLM/SGLang server hosting the MinerU VLM (e.g. a GPU box running MinerU's
# official server on port 30000). Leave blank for the local pipeline backend.
#   MINERU_VLM_SERVER_URL=http://gpu-host:30000
MINERU_VLM_SERVER_URL=
